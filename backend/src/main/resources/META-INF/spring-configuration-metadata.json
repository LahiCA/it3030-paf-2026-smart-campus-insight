{
  "groups": [
    {
      "name": "jwt",
      "description": "JWT Configuration",
      "sourceType": "com.smartcampus.backend.service.AuthService"
    },
    {
      "name": "google",
      "description": "Google OAuth Configuration",
      "sourceType": "com.smartcampus.backend.service.AuthService"
    },
    {
      "name": "admin",
      "description": "Admin Configuration",
      "sourceType": "com.smartcampus.backend.service.AuthService"
    }
  ],
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "description": "JWT secret key for token signing",
      "defaultValue": "your-secret-key-change-in-production-at-least-32-characters"
    },
    {
      "name": "google.client.id",
      "type": "java.lang.String",
      "description": "Google OAuth 2.0 Client ID"
    },
    {
      "name": "admin.emails",
      "type": "java.lang.String",
      "description": "Comma-separated list of admin emails"
    }
  ]
}
