{
  "info": {
    "_postman_id": "smart-campus-api-collection",
    "name": "Smart Campus Operations Hub - API Collection",
    "description": "Complete API testing collection for Smart Campus backend\n\nBase URL: http://localhost:8080/api\n\nEndpoints covered:\n- Authentication (OAuth 2.0 + JWT)\n- User Management (Role-based)\n- Notifications (CRUD + filtering)\n- Notification Listener (Integration)\n\nNote: Replace placeholders with actual values before testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Google OAuth Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verify successful login response",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "});",
                  "",
                  "pm.test('Response has user data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user).to.exist;",
                  "    pm.expect(jsonData.user.id).to.exist;",
                  "    pm.expect(jsonData.user.email).to.exist;",
                  "});",
                  "",
                  "// Save token for subsequent requests",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.token);",
                  "    pm.environment.set('user_id', jsonData.user.id);",
                  "    pm.environment.set('user_email', jsonData.user.email);",
                  "    pm.environment.set('user_role', jsonData.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"googleToken\": \"{{google_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/google",
              "host": ["{{base_url}}"],
              "path": ["auth", "google"]
            },
            "description": "Login with Google OAuth token\n\nRequired:\n- googleToken: Valid JWT token from Google Sign-In\n\nReturns:\n- token: JWT token for API authentication\n- user: User object with id, email, role"
          },
          "response": []
        }
      ]
    },
