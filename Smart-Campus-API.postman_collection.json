                  "",
                  "pm.test('All notifications are unread', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(Array.isArray(jsonData)).to.be.true;",
                  "    if (jsonData.length > 0) {",
                  "        jsonData.forEach(function(notif) {",
